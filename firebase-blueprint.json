{
  "entities": {
    "WatchlistItem": {
      "title": "Watchlist Item",
      "description": "A film, TV series, or anime in the user's watchlist.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "The title of the content." },
        "type": { "type": "string", "enum": ["film", "tv", "anime"], "description": "The type of content." },
        "platform": { "type": "string", "enum": ["Netflix", "Prime Video", "Now", "Disney+"], "description": "The streaming platform." },
        "status": { "type": "string", "enum": ["to-watch", "watching", "watched"], "description": "The current status of the item." },
        "rating": { "type": "number", "description": "User rating from 1 to 5." },
        "moodTags": { "type": "array", "items": { "type": "string" }, "description": "Mood tags associated with the item (e.g., 'happy', 'thrilling')." },
        "userUid": { "type": "string", "description": "The UID of the user who owns this item." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the item was added." }
      },
      "required": ["title", "type", "platform", "status", "userUid", "createdAt"]
    }
  },
  "firestore": {
    "/watchlist/{itemId}": {
      "schema": "WatchlistItem",
      "description": "User's personal watchlist items."
    }
  }
}
